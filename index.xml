    <item>
      <title></title>
      <link>https://tzj2006.github.io/zhufu/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>https://tzj2006.github.io/zhufu/</guid>
      <description>&lt;!DOCTYPE html&gt;

&lt;html lang=&#34;zh-hans&#34; xmlns=&#34;http://www.w3.org/1999/xhtml&#34;&gt;
&lt;head&gt;
    &lt;meta charset=&#34;utf-8&#34; /&gt;
    &lt;title&gt;请领取你的蛇年祝福&lt;/title&gt;
    &lt;style&gt;
        /* 初始时，登录页面显示，主页面隐藏 */
        #login-page {
            display: block;
        }

        #main-page {
            display: none;
        }

        * {
            padding: 0;
            margin: 0;
        }

        body {
            background-color: #ffa069a5;
        }

        header, section, footer {
            border: 3px #fffa00 solid;
            border-radius: 15px;
            box-shadow: 0 10px 20px rgba(0,0,0,0.4);
            padding: 20px 30px;
            margin: 20px;
        }

        header {
            background-color: #cad947b3;
        }

        .登录 {
            line-height: 40px;
            font-size: 24px;
        }

        .姓名输入, .地点输入 {
            width: 50%;
            height: 40px;
            border: 2px #ff7d21e4 solid;
            border-radius: 10px;
            background-color: #F0F4F8;
            font-size: 16px;
            text-indent: 10px;
            outline-color: #55ff00;
        }

        .按钮 {
            margin-top: 30px;
            margin-left: 15px;
            background-color: aqua;
            border: 3px #ff7d21e4 solid;
            border-radius: 10px;
            width: 200px;
            height: 75px;
            display: flex;
            cursor: pointer;
            padding: 10px;
            font-size: 30px;
            font-weight: bold;
            line-height: 50px;
            text-indent: 27px;
        }

        h1 {
            color: #bf2cf6;
            font-size: 50px;
            line-height: 55px;
        }

        .地点 {
            font-size: 24px;
            line-height: 40px;
            font-weight: bold;
        }

        .倒计时 {
            color: red;
            font-size: 34px;
            font-weight: bold;
        }

        .评论区 {
            border: 2px #ff7d21e4 solid;
            border-radius: 15px;
            box-shadow: 0 10px 20px rgba(0,0,0,0.2);
            padding: 10px 15px;
            margin: -10px -17px;
        }

        footer p {
            font-size: 20px;
            color: #5b5b5b;
        }

        .注释 {
            text-indent: 22px;
        }

        .注释 p {
            font-size: 20px;
        }

        .小游戏 {
            margin-bottom: 20px;
        }

        /* 设置评论区的样式 */
        .评论列表 {
            margin: 0;
            padding: 0;
            list-style: none;
        }

        /* 设置每条评论的样式 */
        .评论列表 li {
            font-size: 18px;
            border-bottom: 1px solid #3a3a3ae6; /* 细线分隔 */
            padding: 10px 0 3px 0;
            margin-bottom: 4px;
        }

        /* 设置评论者名字的样式 */
        .评论名字 {
            font-weight: bold;
            margin-right: 5px;
        }

        .评论功能块 {
            display: inline;
        }

        /* 设置输入框和按钮的样式 */
        .评论输入框 {
            height: 35px;
            width: 60%;
            padding: 3px;
            border: 2px solid #161616;
            border-radius: 10px;
            font-size: 17px;
            text-indent: 10px;
            margin-bottom: 18px;
        }

        /* 设置按钮的样式 */
        .提交按钮 {
            height: 50px;
            width: 100px;
            padding: 3px;
            border: 2px solid #161616;
            border-radius: 10px;
            cursor: pointer;
        }
        
        /* 设置输入框和文本区域的样式 */
        .编码输入, .编码输出 {
            width: 40%; /* 初始宽度 */
            height: 60px; /* 初始高度 */
            font-size: 20px;
            line-height: 1.5;
            padding: 5px;
            margin-top: 6px;
            box-sizing: border-box;
            resize: none; /* 禁止用户调整大小 */
            overflow: auto; /* 当内容超出时显示滚动条 */
            word-wrap: break-word; /* 超出宽度时自动换行 */
        }

        /* 设置只读文本区域的样式 */
        .编码输出 {
            background-color: #f0f0f0; /* 浅灰色背景 */
            border: 1px solid #ccc; /* 边框 */
        }
    &lt;/style&gt;
&lt;/head&gt;
&lt;body&gt;
    &lt;div id=&#34;login-page&#34;&gt;
        &lt;header&gt;
            &lt;h1&gt;请登录并领取属于你的新年祝福吧&lt;/h1&gt;
        &lt;/header&gt;
        &lt;main&gt;
            &lt;section class=&#34;登录&#34;&gt;
                &lt;p&gt;&lt;strong&gt;请输入你的姓名：&lt;/strong&gt;&lt;/p&gt;</description>
    </item>
